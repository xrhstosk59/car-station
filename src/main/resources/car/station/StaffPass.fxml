            <Label prefHeight="21.0" prefWidth="226.0" styleClass="lel" text="Αλλαγή κωδικού πρόσβασης" textAlignment="CENTER" textFill="WHITE">
               <font>
                  <Font name="DejaVu Serif Condensed Bold" size="15.0" />
               </font>
            </Label>
            <Label prefHeight="33.0" prefWidth="140.0" styleClass="lel2" text="Τωρινός κωδικός" textAlignment="CENTER" textFill="#365c87">
               <font>
                  <Font name="DejaVu Serif Condensed Bold" size="15.0" />
               </font>
            </Label>
            <TextField fx:id="currentpass" prefHeight="25.0" prefWidth="200.0">
               <VBox.margin>
                  <Insets top="-10.0" />
               </VBox.margin>
            </TextField>
            <Label prefHeight="33.0" prefWidth="165.0" styleClass="lel2" text="Καινούριος κωδικός" textAlignment="CENTER" textFill="#365c87">
