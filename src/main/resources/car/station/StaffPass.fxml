               </font>
            </Label>
            <TextField fx:id="newpass" prefHeight="25.0" prefWidth="200.0">
               <VBox.margin>
                  <Insets top="-10.0" />
               </VBox.margin>
            </TextField>
            <Label prefHeight="27.0" prefWidth="178.0" styleClass="lel2" text="Επιβεβαίωση κωδικού" textAlignment="CENTER" textFill="#365c87">
               <font>
                  <Font name="DejaVu Serif Condensed Bold" size="15.0" />
               </font>
            </Label>
            <TextField fx:id="confirmpass" prefHeight="25.0" prefWidth="200.0">
               <VBox.margin>
                  <Insets top="-10.0" />
               </VBox.margin>
            </TextField>
            <Button fx:id="confirm" mnemonicParsing="false" prefHeight="35.0" prefWidth="111.0" styleClass="bb" text="Επιβεβαίωση" textFill="WHITE">
               <font>
                  <Font name="DejaVu Sans Condensed Bold" size="12.0" />
               </font>
            </Button>
         </children>
      </VBox>
