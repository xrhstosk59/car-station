                  <Font name="DejaVu Serif Condensed Bold" size="20.0" />
               </font>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
               <padding>
                  <Insets right="10.0" />
               </padding>
            </Button>
            <Button fx:id="payacc" onAction="#handlePayment" prefHeight="44.0" prefWidth="160.0" text="Λογαριασμός" textFill="WHITE">
               <font>
                  <Font name="DejaVu Serif Condensed Bold" size="20.0" />
               </font>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
               <padding>
                  <Insets right="5.0" />
               </padding>
            </Button>
         </children>
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
      </VBox>
      <VBox alignment="CENTER" layoutX="290.0" layoutY="91.0" prefHeight="200.0" prefWidth="245.0" spacing="20.0" styleClass="lel2">
